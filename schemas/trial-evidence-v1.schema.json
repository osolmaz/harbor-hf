{
  "$defs": {
    "AgentEvidence": {
      "additionalProperties": false,
      "properties": {
        "logs": {
          "items": {
            "$ref": "#/$defs/FileReference"
          },
          "title": "Logs",
          "type": "array"
        },
        "sessions": {
          "items": {
            "$ref": "#/$defs/FileReference"
          },
          "title": "Sessions",
          "type": "array"
        },
        "trajectories": {
          "items": {
            "$ref": "#/$defs/FileReference"
          },
          "title": "Trajectories",
          "type": "array"
        }
      },
      "required": [
        "sessions",
        "trajectories"
      ],
      "title": "AgentEvidence",
      "type": "object"
    },
    "CompletionEvidence": {
      "additionalProperties": false,
      "properties": {
        "requirements": {
          "items": {
            "$ref": "#/$defs/EvidenceRequirement"
          },
          "title": "Requirements",
          "type": "array"
        },
        "status": {
          "const": "complete",
          "default": "complete",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "requirements"
      ],
      "title": "CompletionEvidence",
      "type": "object"
    },
    "EvidenceRequirement": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "enum": [
            "workspace",
            "agent",
            "judge",
            "verifier"
          ],
          "title": "Name",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "satisfied": {
          "title": "Satisfied",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "required",
        "satisfied"
      ],
      "title": "EvidenceRequirement",
      "type": "object"
    },
    "FileReference": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size": {
          "minimum": 0,
          "title": "Size",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "size",
        "sha256"
      ],
      "title": "FileReference",
      "type": "object"
    },
    "JudgeEvidence": {
      "additionalProperties": false,
      "properties": {
        "exchanges": {
          "items": {
            "$ref": "#/$defs/FileReference"
          },
          "title": "Exchanges",
          "type": "array"
        },
        "expected": {
          "title": "Expected",
          "type": "boolean"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "recorder_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/FileReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "expected"
      ],
      "title": "JudgeEvidence",
      "type": "object"
    },
    "VerifierEvidence": {
      "additionalProperties": false,
      "properties": {
        "judge_selection": {
          "anyOf": [
            {
              "$ref": "#/$defs/FileReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "logs": {
          "items": {
            "$ref": "#/$defs/FileReference"
          },
          "title": "Logs",
          "type": "array"
        },
        "reward": {
          "$ref": "#/$defs/FileReference"
        },
        "scorecard": {
          "$ref": "#/$defs/FileReference"
        },
        "stderr": {
          "$ref": "#/$defs/FileReference"
        },
        "stdout": {
          "$ref": "#/$defs/FileReference"
        }
      },
      "required": [
        "scorecard",
        "reward",
        "stdout",
        "stderr"
      ],
      "title": "VerifierEvidence",
      "type": "object"
    },
    "WorkspaceEvidence": {
      "additionalProperties": false,
      "properties": {
        "archive": {
          "$ref": "#/$defs/FileReference"
        },
        "archive_bytes": {
          "minimum": 0,
          "title": "Archive Bytes",
          "type": "integer"
        },
        "compression": {
          "const": "zstd",
          "default": "zstd",
          "title": "Compression",
          "type": "string"
        },
        "entry_count": {
          "minimum": 0,
          "title": "Entry Count",
          "type": "integer"
        },
        "file_count": {
          "minimum": 0,
          "title": "File Count",
          "type": "integer"
        },
        "index": {
          "$ref": "#/$defs/FileReference"
        },
        "root": {
          "const": "/app",
          "default": "/app",
          "title": "Root",
          "type": "string"
        },
        "status": {
          "const": "captured",
          "default": "captured",
          "title": "Status",
          "type": "string"
        },
        "unpacked_bytes": {
          "minimum": 0,
          "title": "Unpacked Bytes",
          "type": "integer"
        }
      },
      "required": [
        "archive",
        "index",
        "entry_count",
        "file_count",
        "unpacked_bytes",
        "archive_bytes"
      ],
      "title": "WorkspaceEvidence",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "agent": {
      "$ref": "#/$defs/AgentEvidence"
    },
    "campaign_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Campaign Id"
    },
    "captured_at": {
      "format": "date-time",
      "title": "Captured At",
      "type": "string"
    },
    "completion": {
      "$ref": "#/$defs/CompletionEvidence"
    },
    "execution_id": {
      "minLength": 1,
      "title": "Execution Id",
      "type": "string"
    },
    "judge": {
      "$ref": "#/$defs/JudgeEvidence"
    },
    "logical_attempt": {
      "minimum": 1,
      "title": "Logical Attempt",
      "type": "integer"
    },
    "physical_attempt": {
      "minimum": 1,
      "title": "Physical Attempt",
      "type": "integer"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "harbor-hf/trial-evidence/v1",
      "default": "harbor-hf/trial-evidence/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "task_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Task Digest",
      "type": "string"
    },
    "task_name": {
      "minLength": 1,
      "title": "Task Name",
      "type": "string"
    },
    "trial_id": {
      "minLength": 1,
      "title": "Trial Id",
      "type": "string"
    },
    "verifier": {
      "$ref": "#/$defs/VerifierEvidence"
    },
    "workspace": {
      "$ref": "#/$defs/WorkspaceEvidence"
    }
  },
  "required": [
    "run_id",
    "execution_id",
    "trial_id",
    "task_name",
    "task_digest",
    "logical_attempt",
    "physical_attempt",
    "captured_at",
    "workspace",
    "agent",
    "judge",
    "verifier",
    "completion"
  ],
  "title": "TrialEvidenceManifest",
  "type": "object"
}
